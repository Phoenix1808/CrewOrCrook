<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1745">

    <ImageView
        android:id="@+id/star"
        android:layout_width="32dp"
        android:layout_height="35dp"
        android:layout_marginStart="65dp"
        android:layout_marginTop="70dp"
        android:src="@drawable/st"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dottitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REWIRE SYSTEM"
        android:textSize="42sp"
        android:textStyle="normal"
        android:fontFamily="@font/bangers_regular"
        android:textColor="#FFFFFF"
        android:layout_marginTop="45dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/star"
        android:layout_marginStart="10dp"/>

    <TextView
        android:id="@+id/txtSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect each wire to its matching terminal!"
        android:textSize="14sp"
        android:textColor="#F7E74A"
        app:layout_constraintTop_toBottomOf="@id/dottitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="5dp"/>

    <ImageView
        android:id="@+id/blr"
        android:layout_width="298dp"
        android:layout_height="210dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtSubtitle"
        android:layout_marginStart="55dp"
        android:background="@drawable/vector103"/>


    <LinearLayout
        android:id="@+id/gameContainer"
        android:layout_width="390dp"
        android:layout_height="395dp"
        android:layout_marginTop="76dp"
        android:background="@drawable/dotbackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="25dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitle"
        tools:layout_editor_absoluteX="11dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:id="@+id/leftRed"
                style="@style/GameDot"
                android:backgroundTint="#FF4B4B" />

            <View
                android:id="@+id/leftBlue"
                style="@style/GameDot"
                android:backgroundTint="#4BA6FF" />

            <View
                android:id="@+id/leftYellow"
                style="@style/GameDot"
                android:backgroundTint="#FFD24D" />

            <View
                android:id="@+id/leftPurple"
                style="@style/GameDot"
                android:backgroundTint="#B86BFF" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/overlayContainer"
            android:layout_width="0dp"
            android:layout_height="330dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:id="@+id/rightPurple"
                style="@style/GameDot"
                android:backgroundTint="#B86BFF" />

            <View
                android:id="@+id/rightRed"
                style="@style/GameDot"
                android:backgroundTint="#FF4B4B" />

            <View
                android:id="@+id/rightYellow"
                style="@style/GameDot"
                android:backgroundTint="#FFD24D" />

            <View
                android:id="@+id/rightBlue"
                style="@style/GameDot"
                android:backgroundTint="#4BA6FF" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/winText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ TASK COMPLETED ✨"
        android:textColor="#4CAF50"
        android:textSize="26sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/gameContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/help"
        android:layout_width="0dp"
        android:layout_height="110dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gameContainer"
        android:layout_marginTop="20dp"
        android:background="@drawable/frame6"/>





</androidx.constraintlayout.widget.ConstraintLayout>