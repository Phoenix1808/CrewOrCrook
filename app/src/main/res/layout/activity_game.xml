<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".GameActivity"
    android:background="@drawable/tile_bg_purple"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvRoomCode"
        android:text="Room Code: "
        android:textSize="20sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvRole"
        android:text="Role: "
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1951A4"
        app:layout_constraintTop_toBottomOf="@id/tvRoomCode"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvStatus"
        android:text="Waiting For Role: "
        android:textColor="@color/black"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvRole"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvMyPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Position: --"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvNearbyPlayers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nearby Players: 0"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvMyPosition"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvLastMovement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last Movement: --"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvNearbyPlayers"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/btnKill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="KILL"
        android:textColor="@android:color/white"
        android:backgroundTint="@android:color/holo_red_dark"
        android:enabled="false"
        android:layout_marginTop="200dp"
        app:layout_constraintTop_toBottomOf="@id/tvNearbyPlayers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <Button
        android:id="@+id/btnReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/btnKill"
        android:text="REPORT BODY"/>


</androidx.constraintlayout.widget.ConstraintLayout>