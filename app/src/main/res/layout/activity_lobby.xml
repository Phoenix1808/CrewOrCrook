<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LobbyActivity"
    android:padding="24dp">

    <!-- Create Room -->
    <Button
        android:id="@+id/btnCreateRoom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Create Room"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCreateResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create result will appear here"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/btnCreateRoom"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Get Available Rooms -->
    <Button
        android:id="@+id/btnFetchRoom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get Available Rooms"
        app:layout_constraintTop_toBottomOf="@id/tvCreateResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRooms"
        android:layout_width="0dp"
        android:layout_height="200dp"
        app:layout_constraintTop_toBottomOf="@id/btnFetchRoom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Lookup Room -->
    <EditText
        android:id="@+id/etRoomCode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter Room Code"
        app:layout_constraintTop_toBottomOf="@id/rvRooms"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/btnLookupRoom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lookup Room"
        app:layout_constraintTop_toBottomOf="@id/etRoomCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvLookupResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lookup result here"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/btnLookupRoom"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="Start Game"
        app:layout_constraintTop_toBottomOf="@id/tvLookupResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnStartGame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>