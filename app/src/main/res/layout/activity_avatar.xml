<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_bg">


    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Avatar"
        android:textSize="28sp"
        android:fontFamily="@font/bangers_regular"
        android:letterSpacing="0.07"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="112dp"/>


    <FrameLayout
        android:id="@+id/avatarContainer"
        android:layout_width="240dp"
        android:layout_height="240dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintBottom_toTopOf="@id/btnconfirm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp">


        <ImageView
            android:id="@+id/avatar1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/av1"
            android:layout_gravity="top|center_horizontal"/>

        <ImageView
            android:id="@+id/avatar2"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/av2"
            android:layout_gravity="center_vertical|end"/>

        <ImageView
            android:id="@+id/avatar3"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/av3"
            android:layout_gravity="bottom|center_horizontal"/>

        <ImageView
            android:id="@+id/avatar4"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/av4"
            android:layout_gravity="center_vertical|start"/>

        <ImageView
            android:id="@+id/avatar5"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/av5"
            android:layout_gravity="center"/>

    </FrameLayout>


    <ImageView
        android:id="@+id/btnconfirm"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="0dp"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"
        android:contentDescription = "Login Button"
        android:scaleType = "fitCenter"
        android:src="@drawable/confirm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/avatarContainer"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
